# Example environment variables for polymarket-sdk examples

# Base URL for the Polymarket API (adjust if needed)
POLYMARKET_API_BASE=https://api.polymarket.com

# Optional API key or token if your integration requires it
POLYMARKET_API_KEY=your_api_key_here

# Wallet private key for signing (DO NOT COMMIT REAL KEYS)
POLYMARKET_WALLET_PRIVATE_KEY=changeme_private_key

# Network identifier (for example: mainnet, mumbai, etc.)
POLYMARKET_NETWORK=mainnet
