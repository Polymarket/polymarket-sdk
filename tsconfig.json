{
  "compilerOptions": {
    "target": "es2022",
    "module": "nodenext",
    "outDir": "lib",
    "lib": ["es2022", "dom"],
    "sourceMap": false,
    "allowJs": false,
    "declaration": true,
    "declarationDir": "lib",
    "moduleResolution": "nodenext",
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true
  },
  "include": ["src", "test"],
  "exclude": ["node_modules", "lib"]
}
