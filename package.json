{
  "name": "@polymarket/sdk",
  "version": "8.0.1",
  "description": "SDK to simplify common interactions with the Polymarket proxy wallet",
  "author": "Tom French <tom@tomfren.ch>",
  "repository": "https://github.com/Polymarket/polymarket-sdk.git",
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js"
    }
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.30.3",
  "contributors": [
    {
      "name": "Tom French",
      "url": "https://github.com/tomafrench"
    },
    {
      "name": "Mike Shrieve",
      "url": "https://github.com/mshrieve"
    },
    {
      "name": "Jonathan Amenechi",
      "url": "https://github.com/JonathanAmenechi"
    }
  ],
  "dependencies": {
    "viem": "^2.46.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "blockchain",
    "ethereum",
    "matic",
    "typescript"
  ],
  "license": "MIT",
  "scripts": {
    "prebuild": "pnpm clean",
    "build": "tsc --project tsconfig.production.json",
    "clean": "rm -rf ./lib",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "prepack": "pnpm test && pnpm build",
    "test": "vitest run"
  }
}
